class Solution {
    public int maxWater(int arr[]) {
        int l=0;
        int r=arr.length-1;
        int max=0;
        while(r>l){
            int height=Math.abs(r-l);
            max=Math.max(Math.min(arr[r],arr[l])*height,max);
            if(arr[r]>arr[l]){
                l++;
            }else{
                r--;
            }
        }
        return max;
    }
}
