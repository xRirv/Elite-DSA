class Solution {
    public int getMinDiff(int[] arr, int k) {
        Arrays.sort(arr);
        int n=arr.length;
        int res=arr[n-1]-arr[0];
        int minH=0, maxH=0;
        for(int i=1;i<n;i++){
            if(arr[i]-k<0){
                continue;
            }
            minH=Math.min(arr[i]-k, arr[0]+k);
            maxH=Math.max(arr[n-1]-k, arr[i-1]+k);
            res=Math.min(res, maxH-minH);
        }
        return res;
    }
}
