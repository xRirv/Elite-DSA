class Solution {
    public char nonRepeatingChar(String s) {
        int arr[]=new int[26];
        for(char ch:s.toCharArray()){
            arr[((int)ch)-97]++;
        }
        for(char ch:s.toCharArray()){
            if(arr[(int)ch-97]==1){
                return ch;
            }
        }
        return '$';
    }
}
