class Solution {
    public static boolean areAnagrams(String s1, String s2) {
        char ch[]=s1.toCharArray();
        char ch1[]=s2.toCharArray();
        Arrays.sort(ch1);
        Arrays.sort(ch);
        if(s1.length()!=s2.length()){
            return false;
        }
        for(int i=0;i<ch.length;i++){
            if(ch[i]!=ch1[i]){
                return false;
            }
        }
        return true;
    }
}
